/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

/404.html
  X-Robots-Tag: noindex, nofollow

/generated/*
  X-Robots-Tag: noindex, nofollow

/en/articles/hello-world.pdf
  Link: <https://autophany.space/en/articles/hello-world>; rel="canonical"
  X-Robots-Tag: index, follow

/ru/articles/hello-world.pdf
  Link: <https://autophany.space/ru/articles/hello-world>; rel="canonical"
  X-Robots-Tag: index, follow
